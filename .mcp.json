{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@localhost:5432/conveni_sight"
      ]
    },
    "redis": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-redis",
        "--url",
        "redis://localhost:6379"
      ]
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "@docker/mcp-docker"
      ]
    }
  }
}
