# 데이터베이스 (Docker Compose 사용 시)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/conveni_sight

# 로컬 개발 시
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conveni_sight

# JWT 보안 키 (프로덕션에서 반드시 변경)
SECRET_KEY=your-secret-key-change-in-production

# Redis (Docker Compose 사용 시)
REDIS_URL=redis://redis:6379/0

# 로컬 개발 시
# REDIS_URL=redis://localhost:6379/0

# 날씨 API (기상청 단기예보 API)
WEATHER_API_KEY=

# 공휴일 API (공공데이터포털)
HOLIDAY_API_KEY=

# 파일 업로드 설정
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# 앱 설정
APP_NAME=CU 편의점 매출 분석 플랫폼
DEBUG=true
